#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>

sem_t wrt;
int readcount = 0;

void* reader(void* arg) {
    readcount++;
    if(readcount == 1)
        sem_wait(&wrt);

    printf("Reader reading\n");

    readcount--;
    if(readcount == 0)
        sem_post(&wrt);
}

void* writer(void* arg) {
    sem_wait(&wrt);
    printf("Writer writing\n");
    sem_post(&wrt);
}

int main() {
    pthread_t r1, w1;

    sem_init(&wrt, 0, 1);

    pthread_create(&r1, NULL, reader, NULL);
    pthread_create(&w1, NULL, writer, NULL);

    pthread_join(r1, NULL);
    pthread_join(w1, NULL);

    return 0;
}
