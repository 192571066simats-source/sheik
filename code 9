#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>

int main() {
    int shmid;
    char *str;

    shmid = shmget((key_t)1122, 1024, 0666 | IPC_CREAT);
    str = (char*) shmat(shmid, NULL, 0);

    printf("Write Data: ");
    gets(str);

    printf("Data written to memory: %s\n", str);

    shmdt(str);
    return 0;
}
