#include <stdio.h>

int main() {
    int block[5] = {100, 500, 200, 300, 600};
    int process[4] = {212, 417, 112, 426};
    int i, j, worst;

    for(i=0;i<4;i++) {
        worst = -1;
        for(j=0;j<5;j++) {
            if(block[j] >= process[i]) {
                if(worst==-1 || block[j] > block[worst])
                    worst = j;
            }
        }
        if(worst != -1) {
            printf("Process %d allocated to block %d\n", i+1, worst+1);
            block[worst] -= process[i];
        }
    }
    return 0;
}
