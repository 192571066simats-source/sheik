#if defined(Q24)
#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>

int main(void) {
    int fd;
    char buf[128];
    ssize_t n;

    /* --- create / write --- */
    fd = open("demo.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    if (fd < 0) { perror("open"); return 1; }
    const char *msg = "Hello from Q24 – UNIX file management!\n";
    write(fd, msg, strlen(msg));
    close(fd);
    printf("[write] Written to demo.txt\n");

    /* --- read --- */
    fd = open("demo.txt", O_RDONLY);
    if (fd < 0) { perror("open"); return 1; }
    n = read(fd, buf, sizeof(buf) - 1);
    buf[n] = '\0';
    close(fd);
    printf("[read]  Content: %s", buf);

    /* --- rename --- */
    rename("demo.txt", "demo_renamed.txt");
    printf("[rename] demo.txt -> demo_renamed.txt\n");

    /* --- unlink (delete) --- */
    unlink("demo_renamed.txt");
    printf("[unlink] demo_renamed.txt deleted\n");

    return 0;
}
#endif /* Q24 */
